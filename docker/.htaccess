Options -Indexes
RewriteEngine On

# 1. Fichiers existants servis directement
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2. API PHP
RewriteCond %{REQUEST_URI} ^/api
RewriteRule ^ index.php [QSA,L]

# 3. Assets Vite — /assets/... → dist/assets/... (les fichiers sont dans dist/)
RewriteRule ^(assets/.+)$ dist/$1 [L]
RewriteRule ^(favicon\.ico|vite\.svg)$ dist/$1 [L]

# 4. SPA fallback
RewriteRule ^ dist/index.html [L]
